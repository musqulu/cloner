# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Access gate ---
# Optional. When set, all app pages are password protected.
CLONER_ACCESS_PASSWORD=

# --- Supabase (storage + future DB) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Service role: server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Optional override (default: cloner-uploads). Create bucket via supabase/migrations/001_cloner_storage.sql
# SUPABASE_STORAGE_BUCKET=cloner-uploads

# --- Replicate ---
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Required for the talking-head clone video step.
# Example format: owner/model-name. Confirm current input fields on Replicate before use.
REPLICATE_VIDEO_MODEL=
# Override these if the selected model uses different input names.
# REPLICATE_VIDEO_IMAGE_FIELD=image
# REPLICATE_VIDEO_AUDIO_FIELD=audio
# REPLICATE_VIDEO_RESOLUTION_FIELD=resolution
# REPLICATE_VIDEO_RESOLUTION=720p
# REPLICATE_VIDEO_PROMPT_FIELD=prompt
# REPLICATE_VIDEO_OUTPUT_FIELD=video

# --- ElevenLabs ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional overrides for TTS.
# ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
# Optional. Used only by npm run check:providers or /api/provider-check.
# ELEVENLABS_TEST_VOICE_ID=

# Optional. Default: https://api.elevenlabs.io — use EU/residency host if required.
# ELEVENLABS_API_BASE_URL=

# Full URL for POST image generation (when documented for your account).
ELEVENLABS_IMAGE_API_URL=

# Optional: JSON key for the prompt if the endpoint expects something other than "prompt".
# ELEVENLABS_IMAGE_PROMPT_FIELD=prompt
